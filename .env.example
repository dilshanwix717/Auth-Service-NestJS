# ============================================================================
# Auth Service – Environment Variables Reference
# ============================================================================
# Copy this file to .env and fill in real values.
# Every variable is documented below. Required vars have no default.
# ============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development                          # Runtime environment: development | production | test | staging
PORT=3000                                     # HTTP port the server listens on
SERVICE_NAME=auth-service                     # Logical service name for logs and tracing
INTERNAL_API_KEY=CHANGE_ME_internal_key_here  # Shared secret for service-to-service API calls (REQUIRED)

# ─── JWT (RS256 Asymmetric Keys) ─────────────────────────────────────────────
# Generate a key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode them:
#   base64 -w 0 private.pem
#   base64 -w 0 public.pem
JWT_PRIVATE_KEY=BASE64_ENCODED_PRIVATE_KEY    # Base64-encoded RSA private key (REQUIRED)
JWT_PUBLIC_KEY=BASE64_ENCODED_PUBLIC_KEY       # Base64-encoded RSA public key (REQUIRED)
JWT_ALGORITHM=RS256                           # JWT signing algorithm
JWT_ACCESS_TOKEN_EXPIRY=15m                   # Access token lifetime (e.g. 15m, 1h)
JWT_REFRESH_TOKEN_EXPIRY=7d                   # Refresh token lifetime (e.g. 7d, 30d)
JWT_ISSUER=auth-service                       # JWT "iss" claim value
JWT_AUDIENCE=omi-services                     # JWT "aud" claim value

# ─── Database (PostgreSQL / TypeORM) ─────────────────────────────────────────
DB_HOST=localhost                              # PostgreSQL hostname or IP (REQUIRED)
DB_PORT=5432                                   # PostgreSQL port
DB_USERNAME=postgres                           # Database username (REQUIRED)
DB_PASSWORD=CHANGE_ME_db_password              # Database password (REQUIRED)
DB_NAME=auth_db                                # Database name (REQUIRED)
DB_SSL=false                                   # Enable TLS for DB connections
DB_POOL_MIN=2                                  # Minimum connections in the pool
DB_POOL_MAX=10                                 # Maximum connections in the pool

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379               # Full Redis connection URL (REQUIRED)
REDIS_KEY_PREFIX=auth:                         # Key prefix to namespace all Redis keys
REDIS_TLS=false                                # Enable TLS for Redis connections

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672 # AMQP connection URL (REQUIRED)
RABBITMQ_EXCHANGE=auth.events                  # Topic exchange for auth domain events
RABBITMQ_PREFETCH_COUNT=10                     # Max unacknowledged messages per consumer
RABBITMQ_HEARTBEAT_INTERVAL=60                 # AMQP heartbeat interval in seconds

# ─── Password Hashing ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=12                               # bcrypt cost factor (4–31)
ARGON2_MEMORY_COST=65536                       # Argon2 memory in KiB (65536 = 64 MB)
ARGON2_TIME_COST=3                             # Argon2 iteration count
ARGON2_PARALLELISM=4                           # Argon2 thread count

# ─── Security / Brute-Force Protection ──────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5                           # Failed attempts before account lockout
ACCOUNT_LOCKOUT_DURATION_MINUTES=15            # Lockout duration in minutes
MAX_CONCURRENT_SESSIONS=5                      # Max active sessions per user
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60         # Password-reset token lifetime in minutes

# ─── Operational ─────────────────────────────────────────────────────────────
LOG_LEVEL=log                                  # Log level: error | warn | log | debug | verbose
REQUEST_TIMEOUT_MS=30000                       # Global HTTP request timeout in ms
GRACEFUL_SHUTDOWN_TIMEOUT_MS=5000              # Graceful shutdown wait time in ms
